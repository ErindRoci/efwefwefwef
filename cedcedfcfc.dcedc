  arabic:'أَقِمِ الصَّلَاةَ ۖ إِنَّ الصَّلَاةَ تَنْهَىٰ عَنِ الْفَحْشَاءِ وَالْمُنكَرِ',
  arabicTr:'Fale namazin — me të vërtetë namazi ndalon nga të shëmtuarat dhe veprat e këqija.',
  base:`Namazi është shtylla e dytë dhe qendrore e Islamit, shtylla që e dallon muslimanin nga jobesimtari.<br><br>

<strong>Pesë Namazet Ditore dhe Rekatet:</strong><br>
| Namazi | Farz | Sunnet |<br>
|--------|------|--------|<br>
| Sabahu (Fajr) | 2 | 2 para |<br>
| Dreka (Dhuhr) | 4 | 4 para + 2 pas |<br>
| Ikindia (Asr) | 4 | 4 para (Hanafi) |<br>
| Akshami (Maghrib) | 3 | 2 pas |<br>
| Jacia (Isha) | 4 | 4 para + 2 pas + 3 vitër |<br><br>

Profeti ﷺ ka thënë: <em>"Namazi është shtyllë e fesë. Kush e kryen, ka ngritur fenë. Kush e braktis, ka rrënuar fenë."</em>`,
  refs:['El-Bekare 2:43','En-Nisa 4:103','El-Ankebut 29:45','Sahih Buhari 520','Sahih Muslim 682'],
  quranRef:{s:29,a:45},
  hadithRef:{col:'bukhari',num:520},
  madhabs:{
    h:'Hanefijtë e konsiderojnë Vitrin Vaxhib (detyrim). Mënyra e faljes ndryshon paksa — ngritja e duarve vetëm në tekbirin e parë.',
    s:'Shafi\'ijtë lexojnë Bismilah me zë në namazet e zëshme. Falin Kunut në namazin e Sabahut gjithmonë.',
    m:'Malikitë nuk ngrenë duart pos në tekbirin e parë. Nuk lexojnë Bismilah me zë dhe nuk falin Kunut në Sabah zakonisht.',
    b:'Hanbelijtë e njohin Vitrin si Vaxhib. Ngrenë duart në disa vende gjatë namazit sipas sunnetit të Profetit ﷺ.'
  }
},
/* ── ZEKAT ── */
{
  keys:['zekat','zakat','nisab','zeqat','lëmoshë detyruese','detyrë','sadaka e detyrueshme'],
  verdict:'wajib',
  arabic:'وَأَقِيمُوا الصَّلَاةَ وَآتُوا الزَّكَاةَ وَارْكَعُوا مَعَ الرَّاكِعِينَ',
  arabicTr:'Kryejeni namazin, jepni zekatin dhe bini në rukú bashkë me ata që bien.',
  base:`Zekati është shtylla e tretë e Islamit dhe <strong>Farz</strong> absolut për çdo musliman që ka arritur Nisabin për një vit hënor.<br><br>

<strong>Nisabi dhe Norma e Zekatit:</strong><br>
• <strong>Ari:</strong> 85 gramë ari (≈ 7.5 tola)<br>
• <strong>Argjendi:</strong> 595 gramë argjend<br>
• <strong>Norma:</strong> 2.5% e vlerës totale<br>
• <strong>Kushti:</strong> Pasuria të ketë qenë mbi Nisab për 1 vit hënor (Haul)<br><br>

<strong>8 Kategoritë e Përfituesve (El-Muslimin):</strong><br>
1. Të varfrit (Fuqara) · 2. Nevojtarët (Mesakin) · 3. Mbledhësit e zekatit · 4. Ata që duhen tërhequr drejt Islamit · 5. Skllavët për liri · 6. Borxhlinjt · 7. Rruga e Allahut · 8. Udhëtarët e nevojshëm`,
  refs:['Et-Teubeh 9:60','El-Bekare 2:177','Sahih Buhari 1395','Sahih Muslim 982'],
  quranRef:{s:9,a:60},
  hadithRef:{col:'bukhari',num:1395},
  madhabs:{
    h:'Hanefijtë e llogarisin Nisabin bazuar në vlerën e argjendit (595g), gjë që e ul pragun — kështu më shumë njerëz detyrohen.',
    s:'Shafi\'ijtë bazojnë Nisabin në ari (85g). Zekati i bujqësisë ka rregulla specifike (Ushr).',
    m:'Malikitë i japin rëndësi Nisabit të arit. Lejojnë Nisabin e argjendit kur pasuria është e kombinuar.',
    b:'Hanbelijtë e llogarisin Nisabin si vlerën e arit. Trajtojnë detajisht çështjen e zekatit mbi aksionet dhe investimet moderne.'
  }
},
/* ── PRINDËRIT ── */
{
  keys:['prindër','prinder','nënë','nana','atë','baba','familje','birësi','respekt prinder','detyrim prinder'],
