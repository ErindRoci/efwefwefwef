    <div class="sfrow" onclick="openMod('privMod')"><span>🔒</span>Privatësia</div>
    <div class="swm">Eidro AI by Erind Roci</div>
  </div>
</aside>

<!-- MAIN -->
<main id="main">
  <div id="topbar">
    <div class="ham" onclick="document.getElementById('sb').classList.toggle('open')">☰</div>
    <div class="tbc">
      <div class="tbtitle">Eidro Mufti AI</div>
      <div class="tbsub"> 100% Falas </div>
    </div>
    <div class="tbr">
      <div class="ttabs">
        <button class="tab on" onclick="tabSel(this)">✅ Hallall/Haram</button>
        <button class="tab" onclick="tabSel(this)">📚 Fikh</button>
        <button class="tab" onclick="tabSel(this)">🌙 Akide</button>
        <button class="tab" onclick="tabSel(this)">🕌 Namaz</button>
        <button class="tab" onclick="tabSel(this)">🌙 Agjërim</button>
        <button class="tab" onclick="tabSel(this)">💰 Zekat</button>
      </div>
      <div class="status-pill">
        <div class="sdot" id="sdot"></div>
        <span id="slbl">Live · Falas</span>
      </div>
      <div class="ib" onclick="exportChat()" title="Eksporto">📤</div>
      <div class="thpill" onclick="toggleTheme()"><span id="thic">🌙</span>&nbsp;<span id="thlbl">Natë</span></div>
    </div>
  </div>

  <div id="chat">
    <div id="chatMsgs"></div>
    <div id="welcome">
      <div class="wseal">
        <div class="wr"></div><div class="wr2"></div>
        <div class="wcr">⚖️</div>
      </div>
      <div class="war">بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ</div>
      <div class="wtitle">Eidro Mufti AI</div>
      <div class="wdesc">Pyesni çdo pyetje fetare islame dhe merrni përgjigje të strukturuara me vargje të gjalla nga Kurani dhe Hadithi.</div>
      <div class="wpow"><div class="fdot"></div>100% Falas </div>
      <div class="api-info" id="apiInfo">
        <div class="api-chip"><div class="dot loading" id="dotQuran"></div><span id="lblQuran">AlQuran API...</span></div>
        <div class="api-chip"><div class="dot loading" id="dotHadith"></div><span id="lblHadith">Hadith API...</span></div>
        <div class="api-chip"><div class="dot" style="background:var(--j3)"></div><span>Knowledge Base · Aktive</span></div>
      </div>
      <div class="wdisc">⚠️ Ky asistent ofron informacion edukativ islamik. Konsultohuni me dijetar të kualifikuar për vendime të rëndësishme fetare.</div>

      <div class="pgrid">
        <div class="pc" onclick="ask('A është hallall të punosh si programues softueri dhe të ndërtosh aplikacione për kompani të ndryshme?')"><div class="pcic">✅</div><div class="pccat">Hallall &amp; Haram</div><div class="pctxt">A lejohet kjo punë apo veprim sipas Islamit?</div></div>
        <div class="pc" onclick="ask('A prishet agjërimi i Ramazanit nëse pi ujë pa dashje duke harruar?')"><div class="pcic">🌙</div><div class="pccat">Agjërim</div><div class="pctxt">A prishet agjërimi nëse... rregullat e sakta</div></div>
        <div class="pc" onclick="ask('A lejohet marrja e kredisë bankare me interes (kamata) sipas Islamit?')"><div class="pcic">💰</div><div class="pccat">Financa Islame</div><div class="pctxt">A lejohet kamata dhe kredia bankare?</div></div>
        <div class="pc" onclick="ask('Çfarë është shirku, cilat janë llojet e tij dhe pse është gjynahu më i madh?')"><div class="pcic">🌙</div><div class="pccat">Akide</div><div class="pctxt">Shirku — llojet dhe rëndësia</div></div>
        <div class="pc" onclick="ask('Si bëhet teubeja e saktë sipas Islamit dhe cilat janë kushtet e pranimit?')"><div class="pcic">🤲</div><div class="pccat">Pendim</div><div class="pctxt">Si bëhet teube e vërtetë?</div></div>
        <div class="pc" onclick="ask('Çfarë thonë Kurani dhe hadithi për respektin ndaj prindërve?')"><div class="pcic">👨‍👩‍👦</div><div class="pccat">Familja</div><div class="pctxt">Ajete dhe hadithe për prindërit</div></div>
        <div class="pc" onclick="ask('Cilat janë rregullat e zekatit, cili është nisabi dhe si llogaritet?')"><div class="pcic">📊</div><div class="pccat">Zekat</div><div class="pctxt">Rregullat, nisabi dhe llogaritja</div></div>
        <div class="pc" onclick="ask('A është gjynah të dëgjosh muzikë? Cilat janë mendimet e katër medhhebeve?')"><div class="pcic">🎵</div><div class="pccat">Çështje Moderne</div><div class="pctxt">Gjykimi islamik mbi muzikën</div></div>
      </div>
      <div class="chips">
        <div class="chip" onclick="ask('Cili është gjykimi islamik për fotografinë?')">📸 Fotografitë</div>
        <div class="chip" onclick="ask('Cili është gjykimi islamik për tatuazhin?')">✒️ Tatuazhi</div>
        <div class="chip" onclick="ask('A lejohet blerja e Bitcoin sipas Islamit?')">₿ Bitcoin</div>
        <div class="chip" onclick="ask('Rregullat e hixhabit sipas katër medhhebeve')">🧕 Hixhabi</div>
        <div class="chip" onclick="ask('A lejohet sigurimi i jetës në Islam?')">🛡️ Sigurimi</div>
        <div class="chip" onclick="ask('Çfarë thotë Islami për divorcin?')">💍 Divorci</div>
        <div class="chip" onclick="ask('Pesë shtyllat e Islamit dhe kuptimi i tyre')">🕋 5 Shtyllat</div>
        <div class="chip" onclick="ask('Cili është gjykimi i aborsionit sipas Islamit?')">⚕️ Aborcion</div>
        <div class="chip" onclick="ask('A lejohet loja me bixhoz në Islam?')">🎰 Bixhozi</div>
        <div class="chip" onclick="ask('Çfarë janë emrat e bukur të Allahut Esmaul Husna?')">✨ Esmaul Husna</div>
      </div>
    </div>
  </div>

  <div id="inputzone">
    <div class="iw">
      <textarea id="uInput" placeholder="Pyesni çdo gjë rreth Islamit — hallall/haram, namaz, agjërim, Kuran, hadith, moral, familje, fikh..." rows="1" onkeydown="handleKey(event)" oninput="autoResize(this)"></textarea>
      <div class="ibtns">
        <div class="ibb" onclick="speakLast()" title="Dëgjo">🔊</div>
        <button class="sendbtn" id="sendBtn" onclick="sendMsg()">▶</button>
      </div>
    </div>
    <div class="infoline">
      <span>Enter = dërgo · Shift+Enter = rresht · Falas</span>
      <span class="livind"><div class="livdot" id="livdot"></div><span id="livlbl">Eidro Mufti AI · Online</span></span>
    </div>
  </div>
</main>
</div>

<!-- MODALS -->
<div class="ov" id="aboutMod">
  <div class="modal">
    <div class="mh"><div class="mtitle">⚖️ Rreth Eidro Mufti AI</div><div class="mclose" onclick="closeMod('aboutMod')">✕</div></div>
    <p>Eidro Mufti AI është platforma islame shqipfolëse 100% falas, pa pagesë. Ndërtuar mbi burime islame të hapura.</p>
    <p><strong>AlQuran</strong> — Kurani i plotë me 90+ përkthime.<br>
    <strong>Hadith </strong> — Të gjitha koleksionet kryesore hadithi. <br>
    <strong>Knowledge Base</strong> — Bazë e dijes islame e ndërtuar brenda aplikacionit</p>
    <h3>⚠️ Disclaimer</h3>
    <p>Ky asistent ofron <strong>informacion edukativ islamik</strong>. Nuk zëvendëson konsultimin me dijetar të kualifikuar.</p>
    <p style="font-size:.71rem;color:var(--t3);margin-top:14px">Eidro Mufti AI v5.0 · AlQuran.cloud + Hadith CDN · Created by Erind Roci · © 2026</p>
  </div>
</div>
<div class="ov" id="privMod">
  <div class="modal">
    <div class="mh"><div class="mtitle">🔒 Privatësia</div><div class="mclose" onclick="closeMod('privMod')">✕</div></div>
    <p>Asnjë të dhënë nuk ruhet. Nuk nevojitet llogari. Bisedat mbeten vetëm në browser tuaj.</p>
    <p>API calls bëhen direkt nga browser juaj te AlQuran.cloud dhe jsDelivr CDN — serverët tanë nuk shohin asgjë.</p>
    <p style="font-size:.71rem;color:var(--t3);margin-top:14px">© 2026 Eidro Mufti AI — Created by Erind Roci — All Rights Reserved</p>
  </div>
</div>

<div id="footer">© 2026 Eidro Mufti AI &nbsp;|&nbsp; Created by Erind Roci &nbsp;|&nbsp; All Rights Reserved</div>

<script>
/* ═══════════════════════════════════════════════════════
   EIDRO MUFTI AI — ENGINE v5.0
   100% FREE · No API Key · AlQuran.cloud + Hadith CDN
═══════════════════════════════════════════════════════ */

// ── FREE API ENDPOINTS ──
const QURAN_API  = 'https://api.alquran.cloud/v1';
const HADITH_CDN = 'https://cdn.jsdelivr.net/gh/fawazahmed0/hadith-api@1/editions';

// ── STATE ──
let msgs=[], busy=false, mc=0, tc=0;

// ── KNOWLEDGE BASE ──
// Each entry: keys[], verdict, arabic, arabicTr, base, refs[], madhabs{}, quranRef{s,a}, hadithRef{col,num}
const KB = [
/* ── KAMATA / RIBA ── */
{
  keys:['kamat','interes','ribë','rib','kredi bank','hua me interes','hua bankare','financ','bank','banka'],
  verdict:'haram',
  arabic:'وَأَحَلَّ اللَّهُ الْبَيْعَ وَحَرَّمَ الرِّبَا',
  arabicTr:'Allahu ka lejuar shitblerjen dhe ka ndaluar ribën.',
  base:`Kamata (<strong>Riba</strong>) është shprehimisht e ndaluar në Kuranin Fisnik dhe konsiderohet si një ndër gjynahet më të rënda. Allahu ﷻ e ka ndaluar atë katëgorish dhe ka shpallur luftë ndaj atij që e vazhdon.<br><br>

<strong>Llojet e Ribës:</strong><br>
• <strong>Riba en-Nesia</strong> — Shtimi i borxhit për shkak të vonesës në kthim (forma e kredisë bankare moderne)<br>
• <strong>Riba el-Fadl</strong> — Shkëmbimi i mallrave të njëjtit lloj në sasi të pabarabarta<br><br>

Kredinë bankare me interes të fiksuar është unanimisht <strong>Haram</strong> sipas të katër medhhebeve. Alternativa islame janë kontratat Murabaha, Mudarebe dhe Mushareke, të ofruara nga bankat islame.`,
  refs:['El-Bekare 2:275','El-Bekare 2:278-279','Al-Imran 3:130','Sahih Buhari 2086','Sahih Muslim 1598'],
  quranRef:{s:2,a:275},
  hadithRef:{col:'bukhari',num:2086},
  madhabs:{
    h:'Hanefijtë e ndalojnë çdo formë Riba. Lejojnë kontratat alternative islame si Murabaha dhe Ijarah.',
    s:'Shafi\'ijtë janë shumë striktë — çdo shtim i paracaktuar mbi borxh është Riba dhe haram pa asnjë përjashtim.',
    m:'Malikitë e ndalojnë Ribën në të gjitha format e saj. Lejojnë disa transaksione tregtare me kushte shumë specifike.',
    b:'Hanbelijtë e ndalojnë kategorikisht. Ibn Tejmijje dhe Ibn Kajimi kanë shkruar gjerësisht kundër Ribës moderne.'
  }
},
/* ── SHIRK ── */
{
  keys:['shirk','shrik','idhujtari','politeiz','shoqër','zot tjetër','idhull','shirku'],
  verdict:'haram',
  arabic:'إِنَّ اللَّهَ لَا يَغْفِرُ أَن يُشْرَكَ بِهِ وَيَغْفِرُ مَا دُونَ ذَٰلِكَ لِمَن يَشَاءُ',
  arabicTr:'Allahu nuk falë që t\'i shoqërohet shok, por falë çdo gjë tjetër pos kësaj për kë dëshiron.',
  base:`Shirku është gjynahu më i madh në Islam dhe i vetmi gjynah që — nëse personi vdes pa u penduar — nuk falet nga Allahu. Shirku do të thotë t\'i shoqërosh Allahut shok ose rival në adhurim, hyjni ose cilësi hyjnore.<br><br>

<strong>Llojet e Shirkut:</strong><br>
• <strong>Shirk Ekber (i Madh)</strong> — e nxjerr nga Islami: adhurimi i idhujve, besimi se dikush tjetër është hyjni, lutja drejtuar të vdekurve si zotëve<br>
• <strong>Shirk Esger (i Vogël)</strong> — nuk e nxjerr nga Islami por është gjynah i madh: syefaqësia (ria), betimi në dikë tjetër pos Allahut<br>
• <strong>Shirk Khafi (i Fshehtë)</strong> — shirku i zemrës: mbështetja e tepruar tek krijesat pa iu kthyer Allahut`,
  refs:['En-Nisa 4:48','El-Maida 5:72','Luqman 31:13','Sahih Buhari 3456','Sahih Muslim 92'],
  quranRef:{s:4,a:48},
  hadithRef:{col:'bukhari',num:3456},
  madhabs:{
    h:'Hanefijtë e ndalojnë çdo formë Shirku Ekber. Trajtojnë me kujdes çështjet si tevessuli, duke dalluar format e lejuara nga ato jo të lejuara.',
    s:'Shafi\'ijtë e ndalojnë çdo formë Shirku kategorikisht. Tevessuli nëpërmjet Profetit ﷺ lejohet vetëm në formën e duhur.',
    m:'Malikitë janë të rreptë ndaj çdo praktike që mund të çojë drejt Shirkut. Zbatojnë parimin Sed edh-Dheria\'a.',
    b:'Hanbelijtë, sidomos shkolla e Ibn Tejmijes, janë shumë striktë kundër çdo forme Shirku, duke përfshirë vizitat e tepruara të varrezave me besime të gabuara.'
  }
},
/* ── TEUBE ── */
{
  keys:['teube','tobe','pendim','pendohem','penduar','fal gjyna','si falem','gabu','mëkat','mëkate'],
  verdict:'wajib',
  arabic:'يَا أَيُّهَا الَّذِينَ آمَنُوا تُوبُوا إِلَى اللَّهِ تَوْبَةً نَصُوحًا',
  arabicTr:'O ju që besoni! Pendohuni tek Allahu me pendim të sinqertë.',
  base:`Teubja (Pendimi) është detyrë (<strong>Vaxhib</strong>) dhe Allahu e pranon teubjen e sinqertë nga çdo rob të Tij. Profeti ﷺ ka thënë: <em>"Çdo bir i Ademit gabon, dhe më i miri i atyre që gabon është ai që pendon shumë."</em> (Tirmidhi 2499)<br><br>

<strong>Katër Kushtet e Teubjes së Saktë:</strong><br>
1. <strong>El-Ikla</strong> — Heqja dorë menjëherë nga gjynahu<br>
2. <strong>En-Nedem</strong> — Keqardhja e sinqertë dhe pendimi i zemrës<br>
3. <strong>El-Azm</strong> — Vendosmëria për të mos u kthyer kurrë<br>
4. <strong>Redd el-Hukuk</strong> — Kthimi i të drejtave nëse gjynahu ka prekur të drejtat e njerëzve<br><br>

Allahu thotë: <em>"Thuaj: O robërit e Mi që keni gabuar kundër vetëve tuaja, mos e humbni shpresën ndaj mëshirës së Allahut! Allahu i falë të gjitha gjynahet."</em> (Ez-Zumer 39:53)`,
  refs:['Et-Tahrim 66:8','Ez-Zumer 39:53','En-Nisa 4:110','Tirmidhi 2499','Ibn Maxhe 4251'],
  quranRef:{s:66,a:8},
  hadithRef:{col:'tirmidhi',num:3537},
  madhabs:{
    h:'Hanefijtë thonë se teubja pranohet deri në momentin e vdekjes nëse është e sinqertë. Kthimi te gjynahu nuk e anullon teubjen e mëparshme.',
    s:'Shafi\'ijtë e kushtëzojnë teubjen me kushtet e mësipërme. Nëse gjynahu ka lidhje me të drejta njerëzore, duhet kthyer ato ose kërkuar falje.',
    m:'Malikitë theksojnë keqardhjen si kusht qendror. Imam Maliku ka thënë: "Pendimi i zemrës është guri themeltar."',
    b:'Hanbelijtë thonë se teubja e sinqertë fshin gjynahet si të mos kishin ndodhur. Ibn Kajim el-Xhevzijeh ka shkruar librin e famshëm "Medarixh es-Salikin" për teubjen.'
  }
},
/* ── MUZIKA ── */
{
  keys:['muzik','muzikë','këng','keng','instrument','piano','violin','gitarë','rap','pop','hiphop','audio','song'],
  verdict:'makruh',
  arabic:'وَمِنَ النَّاسِ مَن يَشْتَرِي لَهْوَ الْحَدِيثِ لِيُضِلَّ عَن سَبِيلِ اللَّهِ',
  arabicTr:'Ka njerëz që blejnë argëtim të kotë për të devijuar nga rruga e Allahut.',
  base:`Çështja e muzikës është një nga temat ku dijetarët kanë mendime të ndryshme, duke e bërë atë <strong>Çështje të Hapur</strong> me pozicione të ndryshme.<br><br>

<strong>Konsensusi i dijetarëve:</strong><br>
• <strong>Unanimisht Haram:</strong> Muzika me tekste obscene, që nxit degjenerimin moral, alkoholin ose imoralitetin<br>
• <strong>Unanimisht Hallall:</strong> Nasheeidat islame pa instrumente muzikore (ose vetëm me def)<br>
• <strong>Mendime të ndara:</strong> Muzika instrumentale neutrale pa tekst<br>
• <strong>Lejuar me kushte:</strong> Muzika në dasma (def)<br><br>

Profeti ﷺ ka thënë: <em>"Do të vijnë njerëz nga umeti im që do ta lejojnë zinënë, mëndafshin, alkoolin dhe instrumentet muzikore."</em> (Buhari — Muallak)`,
  refs:['Luqman 31:6','Sahih Buhari 5590 (muallak)','El-A\'raf 7:33'],
  quranRef:{s:31,a:6},
  hadithRef:{col:'abudawud',num:3685},
  madhabs:{
    h:'Hanefijtë klasikë e konsiderojnë muzikën si Mekruh Tahrimen (shumë pranë haramit). Shumë dijetarë hanefi modern e dallojnë muzikën neutrale nga ajo e dëmshme.',
    s:'Shafi\'ijtë klasikë, sidomos El-Ghazali, lejojnë instrumnetin def dhe refuzojnë instrumente të tjera. Dijetarë modern shafi\'i janë të ndarë.',
    m:'Malikitë e Andaluzisë historikisht kishin qëndrim më lehtës ndaj muzikës. Ibn Rushd lejon muzikën e moderuar të caktuar.',
    b:'Hanbeli klasikë janë striktë kundër muzikës. Mirëpo Ibn Tejmijje lejon nasheeidat pa instrumente dhe muzikën e dasëm me def.'
  }
},
/* ── AGJËRIM ── */
{
  keys:['agjer','agjër','agjërim','ramazan','siyam','sehur','iftar','oruç','agjon','agjënon'],
  verdict:'wajib',
  arabic:'يَا أَيُّهَا الَّذِينَ آمَنُوا كُتِبَ عَلَيْكُمُ الصِّيَامُ كَمَا كُتِبَ عَلَى الَّذِينَ مِن قَبْلِكُمْ',
  arabicTr:'O ju që besuat, agjërimi u është bërë detyrim, ashtu si ishte detyrë e atyre para jush.',
  base:`Agjërimi i Ramazanit është shtylla e katërt e Islamit dhe <strong>Farz</strong> (detyrim) për çdo musliman të moshës madhore me mendje të shëndoshë dhe të aftë fizikisht.<br><br>

<strong>Gjërat që e PRISHIN agjërimin:</strong><br>
• Ngrënia dhe pirja me dashje dhe me kujtim<br>
• Marrëdhëniet intime gjatë ditës<br>
• Vjellja me qëllim<br>
• Menstruacionet ose lehonia (femrat)<br><br>

<strong>Gjërat që NUK e prishin agjërimin:</strong><br>
• <strong>Ngrënia ose pirja me harresë</strong> — unanimisht nuk e prish<br>
• Injeksionet jo-ushqyese (mjekësore)<br>
• Pështyma e gëlltisur<br>
• Erërat dhe aromat e pavullnetshme<br>
• Largësia (me kushte)`,
  refs:['El-Bekare 2:183','El-Bekare 2:187','Sahih Buhari 1933','Sahih Muslim 1155'],
  quranRef:{s:2,a:183},
  hadithRef:{col:'bukhari',num:1933},
  madhabs:{
    h:'Hanefijtë lejojnë hixhamën (kupëzimin) si të mos e prishë agjërimin. Injeksioni ushqyes e prish, kurse ai mjekësor nuk e prish.',
    s:'Shafi\'ijtë e prishin agjërimin me çdo gjë që hyn në trupin nëpërmjet rrugës natyrale ose vrimave të trupit me qëllim.',
    m:'Malikitë e prishin agjërimin me çfarëdo lëngu nëpërmjet ndonjë rruge të trupit me qëllim.',
    b:'Hanbelijtë e konsiderojnë hixhamën si gjë që e prish agjërimin, bazuar në Hadith të caktuar.'
  }
},
