/* ══ GENERIC REASONING ENGINE ══ */
function smartAnswer(q) {
  const l = q.toLowerCase().normalize('NFC');
  // Find best KB match
  let best=null, bestScore=0;
  for (const e of KB) {
    let score=0;
    for (const k of e.keys) {
      if (l.includes(k.toLowerCase())) score += k.length > 5 ? 15 : 8;
    }
    // Partial word matches
    for (const k of e.keys) {
      for (const w of k.split(' ')) {
        if (w.length > 3 && l.includes(w.toLowerCase())) score += 4;
      }
    }
    if (score > bestScore) { bestScore = score; best = e; }
  }
  if (bestScore >= 4) return best;
  return buildGeneric(q, l);
}

function buildGeneric(q, l) {
  // Detect intent and build intelligent generic response
  const isHH = /hallall|haram|lejohet|ndaluar|gjynah|a mund|a lejohet|a prishet|a është haram|a është hallall/.test(l);
  const isHow = /si bëhet|si falet|si llogar|si veprohet|si bëhemi|si mund/.test(l);
  const isWhat = /çfarë është|cila është|çfarë thotë|çfare thote|çfare ndodh|kush është/.test(l);
  const isWork = /punë|profesion|zanat|detyrë|punëtor|biznes|kompani|shitje|blerje/.test(l);
  const isDua = /dua|lutje|lutem|dhikr|zikr|istighfar|tesbih|salavat/.test(l);
  const isQuran = /kuran|sure|sure|ajeti|varg|ajet/.test(l);
  const isHadith = /hadith|profeti|sunnet|buhari|muslim|tirmidhi/.test(l);

  let base, arabic=null, arabicTr=null, refs=['El-Bekare 2:286','El-Haxhh 22:78'];
  const qRef={s:2,a:286}, hRef={col:'bukhari',num:1};

  if (isWork) {
    arabic='يَا أَيُّهَا الَّذِينَ آمَنُوا لَا تَأْكُلُوا أَمْوَالَكُم بَيْنَكُم بِالْبَاطِلِ';
    arabicTr='O ju besimtarë! Mos e hani pasurinë e njëri-tjetrit me rrugë të padrejta.';
    base=`Islami e vlerëson punën e ndershme shumë lart. Kriteret e hallallit në punë:<br><br>
<strong>Çdo punë apo profesion është HALLALL nëse:</strong><br>
✅ Nuk prodhon ose shet diçka të haramit<br>
✅ Nuk ka mashtrим, dështi ose padrejtësi<br>
✅ Nuk shkakton dëm shoqëror<br>
✅ Nuk ndalohet shprehimisht nga Kurani ose Sunneti<br><br>
Profeti ﷺ ka thënë: <em>"Askush nuk ka ngrënë ushqim më të mirë se ai i fituar me dorën e vet."</em> (Buhari 2072)<br><br>
Specifikoni profesionin konkret dhe do t\'ju jap gjykim të saktë!`;
    refs=['En-Nisa 4:29','El-Xhuma 62:10','Sahih Buhari 2072'];
  } else if (isDua) {
    arabic='وَإِذَا سَأَلَكَ عِبَادِي عَنِّي فَإِنِّي قَرِيبٌ ۖ أُجِيبُ دَعْوَةَ الدَّاعِ إِذَا دَعَانِ';
    arabicTr='Kur të pyesin robërit e Mi për Mua, Unë jam i afërt — i përgjigjem lutjes së atij që më lutet.';
    base=`Lutja (Dua) është adhurimi kryesor — Profeti ﷺ ka thënë: <em>"Dua është ibadeti kryesor."</em><br><br>
<strong>Kushtet e Pranimit të Duas:</strong><br>
• Sinqeriteti i zemrës (Ikhlas)<br>
• Pasja e Allahut si Mëshirues dhe Dëgjues<br>
• Dua me gojë dhe zemër, jo vetëm me gjuhë<br>
• Ushqimi hallall<br>
• Mos u nxitoni — Allahu di kohën e duhur<br><br>
Disa Dua të njohura:<br>
<span style="font-family:var(--fa);color:var(--g2)">رَبَّنَا آتِنَا فِي الدُّنْيَا حَسَنَةً وَفِي الْآخِرَةِ حَسَنَةً</span>`;
    refs=['El-Bekare 2:186','Ghafir 40:60','Tirmidhi 2969'];
  } else if (isQuran) {
    arabic='إِنَّ هَٰذَا الْقُرْآنَ يَهْدِي لِلَّتِي هِيَ أَقْوَمُ';
    arabicTr='Me të vërtetë, ky Kuran udhëzon drejt asaj që është më e drejta.';
    base=`Kurani Fisnik është fjala e Allahut dhe udhëzimi i plotë për njerëzimin. Ka <strong>114 sure</strong> dhe <strong>6236 ajete</strong>.<br><br>
<strong>Suret kryesore dhe rëndësia e tyre:</strong><br>
• <strong>El-Fatiha</strong> — Nëna e Kuranit, 7 ajete<br>
• <strong>El-Bekare</strong> — Surja më e gjatë, 286 ajete<br>
• <strong>Ajetul-Kursi (2:255)</strong> — Mbrojtja më e madhe<br>
• <strong>El-Ikhlas (112)</strong> — Barasvlerëse me 1/3 e Kuranit<br>
• <strong>El-Felak dhe En-Nas</strong> — Suret e mbrojtjes<br><br>
Cila sure ose ajet dëshironi të mësoni?`;
    refs=['El-Isra 17:9','El-Bakara 2:2','Sahih Muslim 798'];
  } else {
    base=`Pyetja juaj shtron çështje të rëndësishme islame.<br><br>
<strong>Parimet Bazë të Fikhut Islamik (Kavaidul Fikh):</strong><br><br>
⚖️ <strong>"El-umuru bi-maqasidiha"</strong> — Veprat gjykohen sipas qëllimeve (Buhari 1)<br><br>
⚖️ <strong>"El-asl fil-ashya el-ibaha"</strong> — Rregulli bazë është se gjërat janë të lejuara derisa të vërtetohet ndalimi<br><br>
⚖️ <strong>"La darar wa la dirar"</strong> — Nuk ka dëm dhe nuk shkaktohet dëm (Ibn Maxhe 2340)<br><br>
⚖️ <strong>"Ed-daruratu tubihul mahzurat"</strong> — Domosdoshmëria e lejon të ndaluarën<br><br>
⚖️ <strong>"El-mashaqqa takhib et-tejsir"</strong> — Vështirësia sjell lehtësi<br><br>
Specifikoni pyetjen tuaj me detaje dhe do t\'ju jap përgjigje me referenca të sakta nga Kurani dhe Hadithi! 🌙`;
    arabic='وَمَا جَعَلَ عَلَيْكُمْ فِي الدِّينِ مِنْ حَرَجٍ';
    arabicTr='Allahu nuk ka vënë mbi ju asnjë vështirësi në fe.';
    refs=['El-Haxhh 22:78','El-Bekare 2:286','Ibn Maxhe 2340'];
  }
  return { arabic, arabicTr, base, refs, verdict:null, madhabs:null, quranRef:qRef, hadithRef:hRef };
}

/* ══ BUILD HTML RESPONSE ══ */
function buildHTML(entry, q) {
  const l = q.toLowerCase();
  const showMadhabs = entry.madhabs && (
    /medhheb|hanafi|shafi|maliki|hanbeli|mendim|mendime|krahasim|dallim/.test(l) || true
  );
  let h = '';
  // Verdict
  const vm = {halal:'vhalal',haram:'vharam',makruh:'vmakruh',wajib:'vwajib',mubah:'vmubah',open:'vopen'};
  const vi = {halal:'✅ HALLALL',haram:'🚫 HARAM',makruh:'⚠️ MEKRUH',wajib:'🟢 VAXHIB',mubah:'🔵 MUBAH',open:'⚖️ ÇËSHTJE E HAPUR'};
  if (entry.verdict) h += `<div class="verdict ${vm[entry.verdict]||'vopen'}">${vi[entry.verdict]||'⚖️'}</div>`;
  // Main text
  h += `<div style="white-space:pre-line;line-height:1.84">${entry.base}</div>`;
  // Arabic
  if (entry.arabic) {
    h += `<span class="aq">${entry.arabic}</span><span class="atr">"${entry.arabicTr}"</span>`;
  }
  // References
  if (entry.refs?.length) {
    h += `<div class="sect"><div class="stitle stg">📚 Referencat</div><div class="refs">${entry.refs.map(r=>`<span class="ref">📌 ${r}</span>`).join('')}</div></div>`;
  }
  // Madhabs
  if (showMadhabs && entry.madhabs) {
    h += `<div class="sect"><div class="stitle stg">🕌 Mendimet sipas Medhhebeve</div><div class="madhabs">
      <div class="md"><div class="mh h">🔵 Hanafi</div><div class="mt">${entry.madhabs.h}</div></div>
      <div class="md"><div class="mh s">🟢 Shafi'i</div><div class="mt">${entry.madhabs.s}</div></div>
      <div class="md"><div class="mh m">🟡 Maliki</div><div class="mt">${entry.madhabs.m}</div></div>
      <div class="md"><div class="mh b">🔴 Hanbeli</div><div class="mt">${entry.madhabs.b}</div></div>
    </div></div>`;
  }
  // Disclaimer
  h += `<div class="disclaim">⚠️ Ky informacion është edukativ islamik. Për çështje personale me peshë, konsultohuni me dijetar të kualifikuar.</div>`;
  return h;
}

/* ══ LIVE QURAN API ══ */
async function fetchQuranVerse(s, a) {
  try {
    const [ar, tr] = await Promise.all([
      fetch(`${QURAN_API}/ayah/${s}:${a}/quran-simple`, {signal:AbortSignal.timeout(7000)}).then(r=>r.json()),
      fetch(`${QURAN_API}/ayah/${s}:${a}/sq.ahmeti`, {signal:AbortSignal.timeout(7000)}).then(r=>r.json())
    ]);
    if (ar.code!==200) return null;
    return { arabic:ar.data.text, tr:tr.data.text, surah:ar.data.surah.englishName, surahAr:ar.data.surah.name, ayah:ar.data.numberInSurah, surahNum:s };
  } catch(e) { return null; }
}

/* ══ LIVE HADITH API ══ */
async function fetchHadith(col, num) {
  const m={'bukhari':'eng-bukhari','muslim':'eng-muslim','abudawud':'eng-abudawud','tirmidhi':'eng-tirmidhi','ibnmajah':'eng-ibnmajah'};
  try {
    const res = await fetch(`${HADITH_CDN}/${m[col]||'eng-bukhari'}/${num}.json`, {signal:AbortSignal.timeout(7000)});
    if (!res.ok) return null;
    const d = await res.json();
    const had = d.hadiths?.[0];
    if (!had) return null;
    return { text:had.text, collection:d.metadata?.name||col, num };
  } catch(e) { return null; }
}

/* ══ ENRICH WITH LIVE APIS ══ */
async function enrichLive(bubId, entry) {
  const bub = document.getElementById('bub-'+bubId);
  if (!bub || !entry) return;
  const parts = [];
  if (entry.quranRef) {
    const v = await fetchQuranVerse(entry.quranRef.s, entry.quranRef.a);
    if (v) parts.push(`<div class="qblock"><div class="qlabel">📖 AlQuran.cloud — Varg i Gjallë</div>
      <span class="qar">${v.arabic}</span>
      <div class="qtr">${v.tr}</div>
      <div class="qmeta">Sure ${v.surahNum}: ${v.surah} · Ajeti ${v.ayah} · api.alquran.cloud</div>
    </div>`);
  }
  if (entry.hadithRef) {
    const h = await fetchHadith(entry.hadithRef.col, entry.hadithRef.num);
    if (h) parts.push(`<div class="hblock"><div class="hlabel">📜 Hadith API — I Gjallë</div>
      <div class="htxt">"${h.text}"</div>
      <div class="hmeta">${h.collection} · Nr. ${h.num} · cdn.jsdelivr.net/hadith-api</div>
    </div>`);
  }
  if (parts.length) {
    const d = document.createElement('div');
    d.innerHTML = parts.join('');
    d.style.animation = 'min .4s ease';
    const disc = bub.querySelector('.disclaim');
    if (disc) bub.insertBefore(d, disc); else bub.appendChild(d);
    scrollBot();
  }
}

/* ══ DOM HELPERS ══ */
function getWrap(){let w=document.querySelector('#chatMsgs .mwrap');if(!w){w=document.createElement('div');w.className='mwrap';document.getElementById('chatMsgs').appendChild(w);}return w;}
function scrollBot(){const c=document.getElementById('chat');c.scrollTop=c.scrollHeight;}
function escH(t){return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function removeEl(id){const e=document.getElementById(id);if(e)e.remove();}

function addUserBub(text) {
  const w=getWrap(),d=document.createElement('div');
  d.className='msg user';
  d.innerHTML=`<div class="av">👤</div><div class="mb"><div class="mn">Ju</div><div class="bub">${escH(text)}</div></div>`;
  w.appendChild(d);scrollBot();
}

function addThink() {
  const id='tk-'+(tc++),w=getWrap(),d=document.createElement('div');
  d.className='msg ai';d.id=id;
  d.innerHTML=`<div class="av">⚖️</div><div class="mb"><div class="mn">Eidro Mufti AI <span class="mv">✓</span></div><div class="thinking"><div class="tdots"><div class="tdot"></div><div class="tdot"></div><div class="tdot"></div></div><span class="tlab">Duke analizuar burimet islame...</span></div></div>`;
  w.appendChild(d);scrollBot();return id;
}

function addAIBub(html, entry) {
  const id='ai-'+(mc++),w=getWrap(),d=document.createElement('div');
  d.className='msg ai';d.id=id;
  d.innerHTML=`<div class="av">⚖️</div><div class="mb">
    <div class="mn">Eidro Mufti AI <span class="mv">✓</span></div>
    <div class="bub" id="bub-${id}"><div id="txt-${id}" style="opacity:0"></div></div>
    <div class="macts" id="acts-${id}" style="opacity:0">
      <button class="ma" onclick="likeIt(this)">👍 Dobishëm</button>
      <button class="ma" onclick="dislikeIt(this)">👎 Jo i saktë</button>
      <button class="ma" onclick="copyBub('bub-${id}')">📋 Kopjo</button>
      <button class="ma" onclick="speakBub('bub-${id}')">🔊 Dëgjo</button>
    </div>
  </div>`;
  w.appendChild(d);scrollBot();
  streamText(document.getElementById('txt-'+id), html, ()=>{
    const a=document.getElementById('acts-'+id);if(a)a.style.opacity='1';scrollBot();
    // After streaming, enrich with live APIs
    enrichLive(id, entry);
  });
  return id;
}

function streamText(el, html, done) {
  el.style.opacity='1';
  const plain=html.replace(/<[^>]+>/g,' ').replace(/\s+/g,' ').trim();
  const chars=plain.split('');let i=0;
  function tick(){
    if(i>=chars.length){el.innerHTML=html;if(done)done();return;}
    const b=Math.min(7,chars.length-i);for(let j=0;j<b;j++)i++;
    el.textContent=chars.slice(0,i).join('');scrollBot();
    setTimeout(tick,8);
  }
  tick();
}

/* ══ SEND ══ */
async function sendMsg() {
  const inp=document.getElementById('uInput');
  const text=inp.value.trim();
  if(!text||busy)return;
  inp.value='';inp.style.height='auto';
  document.getElementById('welcome').style.display='none';
  addUserBub(text);
  msgs.push({r:'user',c:text});
  addHistItem(text.substring(0,36)+(text.length>36?'...':''));
  busy=true;setUIBusy(true);
  const tid=addThink();
  // Simulate thinking time (500-1200ms) then generate response
  const delay=600+Math.random()*700;
  await new Promise(r=>setTimeout(r,delay));
  removeEl(tid);
  const entry=smartAnswer(text);
  const html=buildHTML(entry,text);
  addAIBub(html,entry);
  msgs.push({r:'ai',c:entry.base});
  busy=false;setUIBusy(false);
}

function ask(t){document.getElementById('uInput').value=t;sendMsg();}
function handleKey(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMsg();}}
function autoResize(el){el.style.height='auto';el.style.height=Math.min(el.scrollHeight,132)+'px';}

/* ══ ACTIONS ══ */
function likeIt(btn){btn.classList.toggle('liked');btn.closest('.macts').querySelectorAll('.ma')[1].classList.remove('disliked');showToast('✅ Faleminderit!');}
function dislikeIt(btn){btn.classList.toggle('disliked');btn.closest('.macts').querySelectorAll('.ma')[0].classList.remove('liked');showToast('📝 Faleminderit! Do të mësohem.');}
function copyBub(id){const e=document.getElementById(id);if(e){navigator.clipboard.writeText(e.innerText||e.textContent);showToast('📋 Teksti u kopjua!');}}
function speakBub(id){const e=document.getElementById(id);if(e&&'speechSynthesis'in window){window.speechSynthesis.cancel();const u=new SpeechSynthesisUtterance(e.innerText||e.textContent);u.lang='sq';u.rate=.88;window.speechSynthesis.speak(u);showToast('🔊 Duke lexuar...');}}
function speakLast(){const es=document.querySelectorAll('.msg.ai .bub');if(es.length)speakBub(es[es.length-1].id);else showToast('ℹ️ Nuk ka asnjë përgjigje akoma.');}
function exportChat(){
  if(!msgs.length){showToast('ℹ️ Nuk ka bisedë.');return;}
  let out='════════════════════════════════\n   EIDRO MUFTI AI — BISEDË\n   Created by Erind Roci © 2026\n   AlQuran.cloud + Hadith CDN\n════════════════════════════════\n\n';
  msgs.forEach(m=>{out+=(m.r==='user'?'👤 Pyetja:\n':'⚖️ Eidro Mufti AI:\n')+m.c.replace(/<[^>]+>/g,'')+'\n\n'+'─'.repeat(40)+'\n\n';});
  const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([out],{type:'text/plain;charset=utf-8'}));a.download='eidro-mufti-'+Date.now()+'.txt';a.click();
  showToast('📤 Biseda u eksportua!');
}

/* ══ UI ══ */
function newChat(){msgs=[];document.getElementById('chatMsgs').innerHTML='';document.getElementById('welcome').style.display='';}
function setUIBusy(b){document.getElementById('sendBtn').disabled=b;document.getElementById('livdot').className=b?'livdot busy':'livdot';document.getElementById('livlbl').textContent=b?'Duke gjeneruar...':'Eidro Mufti AI · Online';document.getElementById('sdot').className=b?'sdot busy':'sdot';document.getElementById('slbl').textContent=b?'Duke procesuar...':'Live · Falas';}
function toggleTheme(){const h=document.documentElement,l=h.dataset.theme==='light';h.dataset.theme=l?'dark':'light';document.getElementById('thic').textContent=l?'🌙':'☀️';document.getElementById('thlbl').textContent=l?'Natë':'Ditë';}
function navSel(el){document.querySelectorAll('.ni').forEach(n=>n.classList.remove('on'));el.classList.add('on');}
function tabSel(b){document.querySelectorAll('.tab').forEach(t=>t.classList.remove('on'));b.classList.add('on');}
function filterHist(v){document.querySelectorAll('.hit').forEach(h=>{h.style.display=h.textContent.toLowerCase().includes(v.toLowerCase())||!v?'':'none';});}
function addHistItem(t){const l=document.getElementById('histList'),g=l.querySelector('.hgrp'),d=document.createElement('div');d.className='hit';d.innerHTML=`<span class="hd"></span>${t}`;d.onclick=()=>ask(t);l.insertBefore(d,g.nextSibling);}
function openMod(id){document.getElementById(id).classList.add('open');}
function closeMod(id){document.getElementById(id).classList.remove('open');}
document.querySelectorAll('.ov').forEach(o=>o.addEventListener('click',e=>{if(e.target===o)o.classList.remove('open');}));
function showToast(m){const o=document.querySelector('.toast');if(o)o.remove();const t=document.createElement('div');t.className='toast';t.textContent=m;document.body.appendChild(t);setTimeout(()=>{t.style.transition='opacity .3s';t.style.opacity='0';},2700);setTimeout(()=>t.remove(),3100);}

/* ══ INIT ══ */
(function(){
  // Sparks
  const c=document.getElementById('sparks');
  for(let i=0;i<25;i++){const s=document.createElement('div');s.className='sp';const z=Math.random()*3.5+1.5;s.style.cssText=`width:${z}px;height:${z}px;left:${Math.random()*100}%;animation-duration:${12+Math.random()*16}s;animation-delay:${Math.random()*22}s;opacity:${.1+Math.random()*.4}`;c.appendChild(s);}
  // Intro
  const stats=['Duke lidhur me Quran API...','AlQuran.cloud ✓ Aktive','Hadith CDN ✓ Aktive','Knowledge Base ✓ Aktive','Eidro Mufti AI gati! 🌙'];
  let si=0;const iv=setInterval(()=>{if(si<stats.length)document.getElementById('istat').textContent=stats[si++];else clearInterval(iv);},520);
  setTimeout(()=>document.getElementById('intro').classList.add('out'),3200);
  setTimeout(()=>document.getElementById('intro').style.display='none',4000);
  // Test APIs and update status chips
  setTimeout(async()=>{
    try{
      const r=await fetch(`${QURAN_API}/ayah/1:1`,{signal:AbortSignal.timeout(5000)});
      const dq=document.getElementById('dotQuran'),lq=document.getElementById('lblQuran');
      if(r.ok){dq.className='dot';dq.style.background='var(--j3)';lq.textContent='AlQuran.cloud · Aktive';}
      else{dq.className='dot err';lq.textContent='AlQuran.cloud · Gabim';}
    }catch(e){document.getElementById('dotQuran').className='dot err';document.getElementById('lblQuran').textContent='AlQuran.cloud · Jo aktive';}
    try{
      const r=await fetch(`${HADITH_CDN}/eng-bukhari/1.json`,{signal:AbortSignal.timeout(5000)});
      const dh=document.getElementById('dotHadith'),lh=document.getElementById('lblHadith');
      if(r.ok){dh.className='dot';dh.style.background='var(--j3)';lh.textContent='Hadith CDN · Aktive';}
      else{dh.className='dot err';lh.textContent='Hadith CDN · Gabim';}
    }catch(e){document.getElementById('dotHadith').className='dot err';document.getElementById('lblHadith').textContent='Hadith CDN · Jo aktive';}
  },3500);
})();
</script>
</body>
</html>
