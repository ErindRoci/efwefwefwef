/* ── HIXHAB ── */
{
  keys:['hixhab','hijab','mbulim','vello','niqab','shami','mbulese','veshje femër','veshje grua','mbuloj','burqa'],
  verdict:'wajib',
  arabic:'وَقُل لِّلْمُؤْمِنَاتِ يَغْضُضْنَ مِنْ أَبْصَارِهِنَّ وَيَحْفَظْنَ فُرُوجَهُنَّ',
  arabicTr:'Dhe thuaj besimtareve të ulin shikimet e tyre dhe të ruajnë nderin e tyre.',
  base:`Hixhabi (mbulimi i gruas muslimane) është <strong>Farz</strong> sipas konsensusit të katër medhhebeve. Dallimet janë vetëm në detaje specifike, jo në obligimin themelor.<br><br>

<strong>Kushtet e Hixhabit të Saktë (sipas shumicës):</strong><br>
• Të mbulojë të gjithë trupin pos fytyrës dhe duarve<br>
• Të mos jetë transparent<br>
• Të mos jetë i ngushtë apo i ngushtë<br>
• Të mos jetë parfum i jashtëm<br>
• Të mos i ngjajë veshjes së meshkujve<br>
• Të mos jetë libas esh-shuhra (i famshëm për krenar)`,
  refs:['El-Ahzab 33:59','En-Nur 24:30-31','Sahih Buhari 5536','Abu Daud 4116'],
  quranRef:{s:33,a:59},
  hadithRef:{col:'abudawud',num:4116},
  madhabs:{
    h:'Hanefijtë thonë fytyra dhe duart janë jo-avret dhe nuk duhet mbuluar domosdoshmërisht, mirëpo preferohet mbulimi kur ka fitneh.',
